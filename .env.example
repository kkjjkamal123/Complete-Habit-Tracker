# Firebase config — OPTIONAL.
# Without these, the app runs fully local-first (data stays on the device).
# Fill them in to enable cross-device sync + Google sign-in.
#
# Where to find them:
#   Firebase console → Project settings → General → Your apps → Web app → SDK setup → Config
# Then copy this file to ".env" and paste your values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
